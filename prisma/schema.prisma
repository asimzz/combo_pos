generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(STAFF)
  active    Boolean  @default(true)
  monthlySalary Float? @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
  stockLogs RawMaterialStockLog[]
  salaryPayments SalaryPayment[]
  expenses Expense[]
  creditEntries CreditEntry[]

  @@map("users")
}

model Category {
  id          String @id @default(cuid())
  name        String
  description String?
  active      Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items MenuItem[]

  @@map("categories")
}

model MenuItem {
  id             String  @id @default(cuid())
  name           String
  description    String?
  price          Float
  cost           Float?
  active         Boolean @default(true)
  featured       Boolean @default(false)
  sortOrder      Int     @default(0)
  image          String?
  stock          Int?
  lowStockAlert  Int     @default(10)
  qrCode         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  orderItems OrderItem[]
  rawMaterialUsage RawMaterialUsage[]

  @@map("menu_items")
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique
  status         OrderStatus @default(PENDING)
  customerName   String?
  customerPhone  String?
  notes          String?
  subtotal       Float
  taxAmount      Float
  serviceCharge  Float @default(0)
  discount       Float @default(0)
  total          Float
  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  orderItems OrderItem[]
  payments   Payment[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Float
  total     Float
  notes     String?
  createdAt DateTime @default(now())

  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(COMPLETED)
  transactionId String?
  notes         String?
  createdAt     DateTime      @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model RawMaterial {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  unit        String
  stock       Float
  cost        Float
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usage RawMaterialUsage[]
  stockLogs RawMaterialStockLog[]

  @@map("raw_materials")
}

model RawMaterialUsage {
  id             String   @id @default(cuid())
  quantity       Float
  createdAt      DateTime @default(now())

  rawMaterialId  String
  rawMaterial    RawMaterial @relation(fields: [rawMaterialId], references: [id])
  menuItemId     String
  menuItem       MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("raw_material_usage")
}

model RawMaterialStockLog {
  id            String         @id @default(cuid())
  type          StockLogType
  quantity      Float
  reason        String?
  createdAt     DateTime       @default(now())

  rawMaterialId String
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id])
  userId        String
  user          User @relation(fields: [userId], references: [id])

  @@map("raw_material_stock_logs")
}

model DailySales {
  id          String   @id @default(cuid())
  date        DateTime @unique
  totalOrders Int      @default(0)
  totalSales  Float @default(0)
  totalTax    Float @default(0)
  totalTips   Float @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("daily_sales")
}

model SalaryPayment {
  id         String   @id @default(cuid())
  amount     Float
  month      Int      // 1-12
  year       Int
  notes      String?
  paidBy     String   // Admin user ID who processed the payment
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("salary_payments")
}

model MonthlySalarySummary {
  id            String   @id @default(cuid())
  userId        String
  month         Int      // 1-12
  year          Int
  monthlySalary Float
  totalPaid     Float    @default(0)
  balance       Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, month, year])
  @@map("monthly_salary_summary")
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  expenses Expense[]

  @@map("expense_categories")
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])

  userId String
  user   User @relation(fields: [userId], references: [id])

  @@map("expenses")
}

model CreditEntry {
  id            String   @id @default(cuid())
  customerName  String
  customerPhone String?
  amount        Float
  paidAmount    Float    @default(0)
  description   String?
  settled       Boolean  @default(false)
  settledAt     DateTime?
  createdAt     DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  payments CreditPayment[]

  @@map("credit_entries")
}

model CreditPayment {
  id        String   @id @default(cuid())
  amount    Float
  createdAt DateTime @default(now())

  creditEntryId String
  creditEntry   CreditEntry @relation(fields: [creditEntryId], references: [id], onDelete: Cascade)

  @@map("credit_payments")
}

model DailyOrderCounter {
  id           String   @id @default(cuid())
  date         String   @unique // YYYY-MM-DD format
  counter      Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("daily_order_counter")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MOMO
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum StockLogType {
  IN
  OUT
  ADJUSTMENT
  WASTE
}